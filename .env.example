# Copie este arquivo para ".env" na raiz do projeto e preencha com suas credenciais.
# O docker-compose.yml carrega essas variáveis automaticamente do .env.

# Chave do recurso "Speech" no Azure Portal (obrigatório)
AZURE_SPEECH_KEY=

# Região do recurso Azure Speech, ex.: brazilsouth, eastus (use isto OU AZURE_ENDPOINT abaixo)
AZURE_SPEECH_REGION=

# Endpoint customizado do recurso Azure Speech (alternativa a AZURE_SPEECH_REGION)
AZURE_ENDPOINT=

# Voz usada na geração do áudio (opcional, default: pt-BR-ThalitaMultilingualNeural)
AZURE_SPEECH_VOICE=
